@using Quản_Lý_Cửa_Hàng_Bán_Điện_Thoại.Models

@{
    ViewBag.Title = "Đặt hàng";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<h2 style="text-align:center">THÔNG TIN ĐẶT HÀNG</h2>

@{
    var kh = (KhachHang_TaiKhoan)Session["Taikhoan"];
}

<table align="center" class="table" style="max-width:600px;">

    <tr>
        <td>Họ tên:</td>
        <td style="font-weight:bold">
            @kh.KhachHang.HoTenKH
        </td>
    </tr>

    <tr>
        <td>Email:</td>
        <td style="font-weight:bold">
            @kh.KhachHang.EmailKH
        </td>
    </tr>

    <tr>
        <td>Điện thoại:</td>
        <td style="font-weight:bold">
            @kh.KhachHang.SoDienThoaiKH
        </td>
    </tr>

    <tr>
        <td>Địa chỉ:</td>
        <td style="font-weight:bold">
            @kh.KhachHang.DiaChiKH
        </td>
    </tr>

    <tr>
        <td>Ngày đặt:</td>
        <td style="font-weight:bold">
            @DateTime.Now.ToShortDateString()
        </td>
    </tr>

    <tr>
        <td></td>

        <td>
            <a href="@Url.Action("XacNhanDonHang","GioHang")"
               class="btn btn-success">

                Xác nhận đặt hàng
            </a>
        </td>
    </tr>

</table>