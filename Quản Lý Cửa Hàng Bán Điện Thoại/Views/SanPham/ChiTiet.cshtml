@model Quản_Lý_Cửa_Hàng_Bán_Điện_Thoại.Models.SanPham

<div class="container mt-5">

    <div class="row">

        <!-- HÌNH ẢNH -->
        <div class="col-md-5 text-center">
            <img alt="@Model.TenSP"
     src="~/HinhDienThoai/@Model.HinhAnh"width="200" />
                 class="img-fluid rounded shadow"
                 style="max-height:400px; object-fit:contain;" />
        </div>

        <!-- THÔNG TIN SẢN PHẨM -->
        <div class="col-md-7">

            <h2 class="fw-bold">@Model.TenSP</h2>

            <p class="text-muted">
                Mã sản phẩm: @Model.MaSP
            </p>

            <h3 class="text-danger fw-bold">
                @String.Format("{0:N0}", Model.Gia) VNĐ
            </h3>

            <p>
                <strong>Số lượng còn:</strong> @Model.SoLuongTon
            </p>

            <p>
                <strong>Mô tả:</strong> @Model.MoTa
            </p>

            <hr />

            <!-- NÚT GIỎ HÀNG -->
            <a href="@Url.Action("ThemGioHang", "GioHang", new { id = Model.MaSP })"
               class="btn btn-success btn-lg">

                🛒 Thêm vào giỏ hàng
            </a>

        </div>

    </div>

</div>