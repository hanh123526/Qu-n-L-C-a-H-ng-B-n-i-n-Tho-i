    <div class="container">

        <div class="row">

            <div class="col-md-4">

                <h5 class="fw-bold mb-4">
                    IT4People
                </h5>

                <p>
                    Cửa hàng điện thoại uy tín,
                    giá rẻ, chính hãng.
                </p>

            </div>

            <div class="col-md-4">

                <h5 class="fw-bold mb-4">
                    Hỗ trợ
                </h5>

                <p>Trung tâm trợ giúp</p>
                <p>Chính sách bảo hành</p>
                <p>Chính sách vận chuyển</p>

            </div>

            <div class="col-md-4">

                <h5 class="fw-bold mb-4">
